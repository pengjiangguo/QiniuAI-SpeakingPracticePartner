# 应用配置
APP_NAME=Speaking Practice Partner - AI Service
APP_VERSION=1.0.0
DEBUG=True

# 服务配置
HOST=0.0.0.0
PORT=8000

# Java服务配置
JAVA_SERVICE_URL=http://localhost:8080/api

# Java环境配置（可选）
# 如果不配置此项，程序将自动检测系统环境中的Java
# 优先级：此配置 > JAVA_HOME环境变量 > 系统PATH
# 配置示例（Windows）: JAVA_HOME=D:/config/jdk-17
# 配置示例（Linux）: JAVA_HOME=/usr/lib/jvm/java-17
JAVA_HOME=D:\config\jdk-17

# 腾讯云配置
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_ASR_APP_ID=your_app_id

# DeepSeek配置
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型配置
SPACY_MODEL=en_core_web_sm
GRAMMAR_MODEL=vennify/t5-base-grammar-correction

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# 文件存储配置
AUDIO_STORAGE_PATH=./storage/audio
MODEL_CACHE_PATH=./storage/models
